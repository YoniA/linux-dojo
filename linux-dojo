lesson_file_comparison() {
    header
    center "${BOLD}${YELLOW}── LESSON 11: File Comparison ──${RESET}"
    echo
    printf "  Compare and reconcile files:\n\n"
    printf "  ${CYAN}diff file1 file2${RESET}            show differences\n"
    printf "  ${CYAN}diff -u file1 file2${RESET}         unified diff (patch-friendly)\n"
    printf "  ${CYAN}diff -r dir1 dir2${RESET}           compare directory trees\n"
    printf "  ${CYAN}patch file < patch.diff${RESET}     apply a diff to a file\n"
    printf "  ${CYAN}patch -p1 < patch.diff${RESET}      apply unified diff (strip 1 path component)\n"
    printf "  ${CYAN}comm file1 file2${RESET}            lines unique/common between sorted files\n"
    printf "  ${CYAN}comm -12 file1 file2${RESET}        only common lines\n"
    printf "  ${CYAN}comm -23 file1 file2${RESET}        only in file1 (not file2)\n"
    printf "  ${CYAN}comm -13 file1 file2${RESET}        only in file2 (not file1)\n"
    echo
    printf "  ${DIM}Note: comm requires both files to be sorted.${RESET}\n"
    echo
    press_enter

    # Challenge 1: diff two files
    local a1; a1=$(new_arena)
    printf 'line one\nline two\nline three\n' > "$a1/v1.txt"
    printf 'line one\nline TWO\nline three\n' > "$a1/v2.txt"

    run_linux_challenge \
        "Find the difference" \
        "'v1.txt' and 'v2.txt' differ on one line.\nRun diff on them and save the output to 'changes.diff'." \
        "$a1" \
        '[[ -f changes.diff ]] && grep -q "TWO\|two" changes.diff' \
        "diff v1.txt v2.txt > changes.diff" \
        "diff v1.txt v2.txt > changes.diff" \
        15

    # Challenge 2: apply a patch
    local a2; a2=$(new_arena)
    printf 'Hello world\nfoo bar\nbaz qux\n' > "$a2/file.txt"
    diff -u /dev/null /dev/null > /dev/null 2>&1  # warm up
    cat > "$a2/fix.patch" << 'PATCHEOF'
--- file.txt
+++ file.txt
@@ -1,3 +1,3 @@
-Hello world
+Hello earth
 foo bar
 baz qux
PATCHEOF

    run_linux_challenge \
        "Apply a patch" \
        "'file.txt' needs an update described in 'fix.patch'.\nApply the patch so 'file.txt' says 'Hello earth' instead of 'Hello world'." \
        "$a2" \
        'grep -qx "Hello earth" file.txt && ! grep -q "Hello world" file.txt' \
        "patch file.txt < fix.patch  (or: patch < fix.patch)" \
        "patch file.txt < fix.patch" \
        20

    # Challenge 3: unified diff
    local a3; a3=$(new_arena)
    printf 'version 1\nshared line\nold content\n' > "$a3/original.txt"
    printf 'version 1\nshared line\nnew content\n' > "$a3/updated.txt"

    run_linux_challenge \
        "Generate a unified diff" \
        "Create a patch file 'update.patch' that captures the differences\nbetween 'original.txt' and 'updated.txt' in unified format (-u)." \
        "$a3" \
        '[[ -f update.patch ]] && grep -q "^---\|^+++" update.patch && grep -q "old content\|new content" update.patch' \
        "diff -u original.txt updated.txt > update.patch" \
        "diff -u original.txt updated.txt > update.patch" \
        15

    # Challenge 4: comm — find common lines
    local a4; a4=$(new_arena)
    printf 'apple\nbanana\ncherry\nmango\n' > "$a4/list_a.txt"
    printf 'banana\ncherry\ngrape\nkiwi\n'  > "$a4/list_b.txt"

    run_linux_challenge \
        "Find common entries" \
        "'list_a.txt' and 'list_b.txt' (both sorted) share some fruit.\nWrite only the lines that appear in BOTH files to 'common.txt'." \
        "$a4" \
        '[[ -f common.txt ]] && grep -qx "banana" common.txt && grep -qx "cherry" common.txt && ! grep -q "apple\|mango\|grape\|kiwi" common.txt' \
        "comm -12 list_a.txt list_b.txt > common.txt" \
        "comm -12 list_a.txt list_b.txt > common.txt" \
        20

    # Challenge 5: comm — lines only in one file
    local a5; a5=$(new_arena)
    printf 'alpha\nbeta\ngamma\ndelta\n' > "$a5/baseline.txt"
    printf 'alpha\ngamma\nepsilon\nzeta\n' > "$a5/current.txt"

    run_linux_challenge \
        "Find removed entries" \
        "'baseline.txt' and 'current.txt' are sorted lists.\nFind the lines that are in 'baseline.txt' but NOT in 'current.txt'.\nWrite them to 'removed.txt'." \
        "$a5" \
        '[[ -f removed.txt ]] && grep -qx "beta" removed.txt && grep -qx "delta" removed.txt && ! grep -q "alpha\|gamma\|epsilon\|zeta" removed.txt' \
        "comm -23 baseline.txt current.txt > removed.txt" \
        "comm -23 baseline.txt current.txt > removed.txt" \
        20

    # Challenge 6: diff directories
    local a6; a6=$(new_arena)
    mkdir -p "$a6/dir_a" "$a6/dir_b"
    printf 'same\n'      > "$a6/dir_a/shared.txt"
    printf 'same\n'      > "$a6/dir_b/shared.txt"
    printf 'only in a\n' > "$a6/dir_a/exclusive.txt"
    printf 'only in b\n' > "$a6/dir_b/other.txt"

    run_linux_challenge \
        "Compare two directories" \
        "'dir_a' and 'dir_b' have some files in common and some unique to each.\nDiff the two directories recursively and save the result to 'tree.diff'." \
        "$a6" \
        '[[ -f tree.diff ]] && grep -q "exclusive\|other" tree.diff' \
        "diff -r dir_a dir_b > tree.diff" \
        "diff -r dir_a dir_b > tree.diff" \
        20
}

