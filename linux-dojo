    printf 'config\n'               > "$a8/config.cfg"
    chmod 644 "$a8/config.cfg"
    printf '#!/bin/bash\necho go\n' > "$a8/start.sh"
    chmod 755 "$a8/start.sh"

    run_linux_challenge \
        "Find executable files" \
