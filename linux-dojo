        25
}

lesson_integrity() {
    # portable sha256: prefer sha256sum (Linux), fall back to shasum -a 256 (macOS)
    _sha256() { sha256sum "$@" 2>/dev/null || shasum -a 256 "$@"; }
    _sha256c() { sha256sum -c "$@" 2>/dev/null || shasum -a 256 -c "$@"; }

    header
    center "${BOLD}${YELLOW}── LESSON 12: File Integrity & Checksums ──${RESET}"
    echo
    printf "  Verify that files are what they claim to be:\n\n"
    printf "  ${CYAN}md5sum file${RESET}               compute MD5 hash\n"
    printf "  ${CYAN}md5sum -c file.md5${RESET}        verify against stored hash\n"
    printf "  ${CYAN}sha256sum file${RESET}             compute SHA-256 hash\n"
    printf "  ${CYAN}sha256sum -c file.sha256${RESET}   verify against stored hash\n"
    printf "  ${CYAN}shasum -a 256 file${RESET}         macOS equivalent of sha256sum\n"
    printf "  ${CYAN}shasum -a 512 file${RESET}         SHA-512 (stronger)\n"
    printf "  ${CYAN}file somefile${RESET}              identify file type by content\n"
    printf "  ${CYAN}file *${RESET}                     identify all files in dir\n"
    printf "  ${CYAN}gpg --verify file.sig file${RESET} verify a GPG signature\n"
    printf "  ${CYAN}gpg --fingerprint keyid${RESET}    inspect a key's fingerprint\n"
    echo
    printf "  ${DIM}Note: md5 is fast but broken for security — use SHA-256 or better.${RESET}\n"
    printf "  ${DIM}      On macOS use 'shasum -a 256' if 'sha256sum' is unavailable.${RESET}\n"
    echo
    press_enter

    # Challenge 1: generate a SHA-256 checksum
    local a1; a1=$(new_arena)
    printf 'important data\n' > "$a1/payload.txt"

    run_linux_challenge \
        "Generate a SHA-256 checksum" \
        "Compute the SHA-256 hash of 'payload.txt' and save it to 'payload.sha256'.\nThe file should be in the standard checksum format (hash + filename).\n\n${DIM}Tip: sha256sum payload.txt > payload.sha256\n     (macOS: shasum -a 256 payload.txt > payload.sha256)${RESET}" \
        "$a1" \
        '[[ -f payload.sha256 ]] && (cd "'"$a1"'" && _sha256c payload.sha256) &>/dev/null' \
        "sha256sum payload.txt > payload.sha256  (macOS: shasum -a 256 payload.txt > payload.sha256)" \
        "sha256sum payload.txt > payload.sha256" \
        15

    # Challenge 2: verify an untampered file
    local a2; a2=$(new_arena)
    printf 'verified content\n' > "$a2/release.tar.gz"
    _sha256 "$a2/release.tar.gz" > "$a2/release.tar.gz.sha256" 2>/dev/null

    run_linux_challenge \
        "Verify a file's checksum" \
        "'release.tar.gz' and its checksum file 'release.tar.gz.sha256' are provided.\nVerify the file is intact. Write 'OK' to 'result.txt' if it passes, 'FAIL' if not.\n\n${DIM}Tip: sha256sum -c release.tar.gz.sha256  (exits 0 on success)${RESET}" \
        "$a2" \
        '[[ -f result.txt ]] && grep -qx "OK" result.txt' \
        "sha256sum -c release.tar.gz.sha256 && echo OK > result.txt || echo FAIL > result.txt" \
        "sha256sum -c release.tar.gz.sha256 && echo OK > result.txt || echo FAIL > result.txt" \
        20

    # Challenge 3: detect a tampered file
    local a3; a3=$(new_arena)
    printf 'original content\n' > "$a3/package.bin"
    _sha256 "$a3/package.bin" > "$a3/package.sha256" 2>/dev/null
    printf 'tampered content\n' > "$a3/package.bin"   # silently overwrite

    run_linux_challenge \
        "Detect a tampered file" \
        "'package.bin' was modified after its checksum was recorded in 'package.sha256'.\nVerify the checksum. Write 'OK' to 'result.txt' if it passes, 'FAIL' if not." \
        "$a3" \
        '[[ -f result.txt ]] && grep -qx "FAIL" result.txt' \
        "sha256sum -c package.sha256 && echo OK > result.txt || echo FAIL > result.txt" \
        "sha256sum -c package.sha256 && echo OK > result.txt || echo FAIL > result.txt" \
        20

    # Challenge 4: checksum multiple files
    local a4; a4=$(new_arena)
    printf 'file one\n'   > "$a4/a.txt"
    printf 'file two\n'   > "$a4/b.txt"
    printf 'file three\n' > "$a4/c.txt"

    run_linux_challenge \
        "Checksum a batch of files" \
        "Generate SHA-256 checksums for all .txt files at once\nand save them to 'checksums.sha256'." \
        "$a4" \
        '[[ -f checksums.sha256 ]] && grep -q "a.txt" checksums.sha256 && grep -q "b.txt" checksums.sha256 && grep -q "c.txt" checksums.sha256 && (cd "'"$a4"'" && _sha256c checksums.sha256) &>/dev/null' \
        "sha256sum *.txt > checksums.sha256  (macOS: shasum -a 256 *.txt > checksums.sha256)" \
        "sha256sum *.txt > checksums.sha256" \
        20

    # Challenge 5: identify file types with `file`
    local a5; a5=$(new_arena)
    # Create files whose content doesn't match their extension
    printf '#!/bin/bash\necho hi\n' > "$a5/mystery.dat"   # actually a shell script
    printf 'GIF87a'                 > "$a5/photo.txt"      # actually a GIF header
    printf 'normal text\n'          > "$a5/readme.log"     # plain text

    run_linux_challenge \
        "Identify file types by content" \
        "The extensions of the files here are misleading.\nRun 'file' on all files and save the output to 'types.txt'.\nThen answer: which file is actually a shell script? Write its name to 'script.txt'." \
        "$a5" \
        '[[ -f types.txt ]] && grep -qi "shell\|bash\|script" types.txt && [[ -f script.txt ]] && grep -qx "mystery.dat" script.txt' \
        "file * > types.txt  then: echo mystery.dat > script.txt" \
        "file * > types.txt ; echo mystery.dat > script.txt" \
        20

    unset -f _sha256 _sha256c
}

# ── Quick reference ───────────────────────────────────────────────────────────

quick_reference() {
    # _ref: one two-column row. Args are plain text; colors live in the format
    # string so %-Ns counts only visible characters.
    _ref() {
        printf "  ${CYAN}%-22s${RESET}  %-18s" "$1" "$2"
        [[ -n "${3:-}" ]] && printf "  ${CYAN}%-22s${RESET}  %s" "$3" "${4:-}"
        printf "\n"
    }
    # _hdr: section header pair; right title starts at same column as right cmd
    _hdr() {
        printf "\n  ${BOLD}${CYAN}%-44s${RESET}${BOLD}${CYAN}%s${RESET}\n" "${1:-}" "${2:-}"
    }

    header
    center "${BOLD}${YELLOW}── QUICK REFERENCE ──${RESET}"

    _hdr "NAVIGATION"        "FILE OPS"
    _ref "ls -la"            "list w/ hidden"    "cp src dst"        "copy"
    _ref "pwd"               "print dir"         "mv src dst"        "move / rename"
    _ref "cd -"              "previous dir"      "rm -r dir"         "remove recursively"
    _ref "find . -name 'p'"  "search by name"    "mkdir -p a/b/c"    "create nested dirs"
    _ref "find . -type f"    "files only"        "touch file"        "create / update"

    _hdr "TEXT PROCESSING"   "REDIRECTION"
    _ref "grep 'p' f"        "match lines"       "cmd > f"           "write stdout"
    _ref "grep -v 'p' f"     "invert match"      "cmd >> f"          "append stdout"
    _ref "sort -n"           "numeric sort"      "cmd 2>/dev/null"   "discard errors"
    _ref "sort | uniq -c"    "count dupes"       "cmd1 | cmd2"       "pipe"
    _ref "cut -d, -f2"       "csv field 2"       "tee file"          "stdout + file"
    _ref "wc -l"             "count lines"

    _hdr "PERMISSIONS"       "ARCHIVES"
    _ref "chmod +x f"        "add execute"       "tar cvf a.tar dir" "create"
    _ref "chmod 644 f"       "rw-r--r--"         "tar xvf a.tar"     "extract"
    _ref "chmod 755 f"       "rwxr-xr-x"         "tar czvf f.tar.gz" "create + gzip"
    _ref "chmod 700 f"       "rwx------"         "tar tzf f.tar.gz"  "list contents"

    _hdr "FIND + XARGS"      "SED & AWK"
    _ref "find . -name/-iname" "name (case-insens)" "sed 's/a/b/g' f"  "replace all"
    _ref "find . -type f/d/l"  "type filter"        "sed '/pat/d' f"   "delete lines"
    _ref "find . -size +1M"    "size filter"        "awk '{print \$2}'" "print field 2"
    _ref "find . -mtime -7"    "modified N days"    "awk '\$3>10'"      "filter rows"
    _ref "find . -perm -u+x"   "perm filter"        "awk '{s+=\$1} END{print s}'" "sum col"
    _ref "find . -exec {} +"   "run per result"     "xargs -I{} cmd {}" "placeholder sub"
    _ref "find . -delete"      "delete matches"

    _hdr "PROCESS & SYSTEM"  "FILE COMPARISON"
    _ref "ps aux"            "all processes"     "diff a b"          "show differences"
    _ref "kill PID"          "send SIGTERM"      "diff -u a b"       "unified diff"
    _ref "kill -9 PID"       "force kill"        "diff -r d1 d2"     "compare dirs"
    _ref "date '+%Y-%m-%d'"  "format date"       "patch f < p.diff"  "apply patch"
    _ref "du -sh dir"        "dir size"          "comm -12 a b"      "common lines"
    _ref "df -h"             "free space"        "comm -23 a b"      "only in a"
    _ref "id -un"            "username"          "comm -13 a b"      "only in b"

    _hdr "FILE INTEGRITY"    ""
    _ref "sha256sum file"       "compute SHA-256"   "sha256sum -c f.sha256" "verify"
    _ref "shasum -a 256 file"   "macOS SHA-256"     "shasum -a 512 file"    "SHA-512"
    _ref "md5sum file"          "compute MD5"       "md5sum -c f.md5"       "verify MD5"
    _ref "file somefile"        "type by content"   "file *"                "identify all"
    _ref "gpg --verify f.sig f" "verify GPG sig"    "gpg --fingerprint id"  "inspect key"

    _hdr "BASH SCRIPTING"    ""
    _ref "VAR=val"              "assign"            "\$1 \$@ \$#"       "args"
    _ref "if [[ -f f ]]; then"  "file test"         "\${v##*/}"         "strip path"
    _ref "for f in *.txt; do"   "glob loop"         "\${v%.*}"          "strip extension"
    _ref "while [[ cond ]]; do" "while loop"        "\${v/a/b}"         "replace in var"
    _ref "fname() { ...; }"     "define function"   "exit N"            "exit with code"
    _ref "\$?"                  "last exit status"  "set -euo pipefail" ""

    echo
    unset -f _ref _hdr
    press_enter
}

