#!/usr/bin/env bash
# linux-dojo — Interactive Linux Command Practice
# Usage: bash linux-dojo

set -uo pipefail

# ── Colors ────────────────────────────────────────────────────────────────────
RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
MAGENTA=$'\033[0;35m'
CYAN=$'\033[0;36m'
WHITE=$'\033[1;37m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
RESET=$'\033[0m'

# ── Game state ────────────────────────────────────────────────────────────────
SCORE=0
STREAK=0
LEVEL=1
CHALLENGES_DONE=0
HINTS_USED=0

TMPDIR_GAME=$(mktemp -d)
trap 'rm -rf "$TMPDIR_GAME"' EXIT

# ── UI helpers ────────────────────────────────────────────────────────────────
clear_screen() { printf '\033[2J\033[H'; }

center() {
    local text="$1"
    local width; width=$(tput cols 2>/dev/null || echo 80)
    local plain; plain=$(printf '%s' "$text" | sed 's/\x1b\[[0-9;]*m//g')
    local plen=${#plain}
    local pad=$(( (width - plen) / 2 ))
    (( pad < 0 )) && pad=0
    printf "%${pad}s%s\n" "" "$text"
}

divider() {
    local width; width=$(tput cols 2>/dev/null || echo 80)
    printf "${DIM}"
    printf '%0.s─' $(seq 1 "$width")
    printf "${RESET}\n"
}

header() {
    clear_screen
    echo
    center "${BOLD}${BLUE}>_  LINUX DOJO  _<${RESET}"
    center "${DIM}Practice Linux commands. Master the shell.${RESET}"
    echo
    divider
    printf "  ${YELLOW}Score: ${WHITE}%-6d${RESET}  ${MAGENTA}Streak: ${WHITE}%-3d${RESET}  ${CYAN}Level: ${WHITE}%-2d${RESET}  ${GREEN}Done: ${WHITE}%d${RESET}\n" \
        "$SCORE" "$STREAK" "$LEVEL" "$CHALLENGES_DONE"
    divider
    echo
}

press_enter() {
    printf "\n  ${DIM}Press Enter to continue...${RESET}"
    read -r
}

show_dir_state() {
    local dir="$1"
    local out
    out=$(cd "$dir" && find . | sort | head -25 2>/dev/null)
    if [[ -n "$out" ]]; then
        echo "$out" | while IFS= read -r line; do
            printf "  ${DIM}%s${RESET}\n" "$line"
        done
    else
        printf "  ${DIM}(empty directory)${RESET}\n"
    fi
}

# ── Arena helpers ─────────────────────────────────────────────────────────────
new_arena() {
    local arena
    arena="$TMPDIR_GAME/arena_$RANDOM"
    mkdir -p "$arena"
    echo "$arena"
}

# ── Challenge engine ──────────────────────────────────────────────────────────
run_linux_challenge() {
    local title="$1"
    local desc="$2"
    local arena="$3"
    local check_code="$4"
    local hint="$5"
    local answer="$6"
    local points="${7:-10}"

    header
    printf "  ${BOLD}${WHITE}CHALLENGE: ${YELLOW}%s${RESET}\n\n" "$title"
    while IFS= read -r line; do
        printf "  %s\n" "$line"
    done <<< "$(printf '%b' "$desc")"
    echo
    divider
    printf "  ${CYAN}Working directory:${RESET} ${DIM}%s${RESET}\n\n" "$arena"
    show_dir_state "$arena"
    echo
    divider
    printf "  ${DIM}[Points: %d]  h = hint   s = skip   Enter = open shell${RESET}\n" "$points"
    echo
    printf "  ${GREEN}▶  ${RESET}"

    local choice hint_used=0
    read -r choice

    if [[ "$choice" == "s" ]]; then
        printf "\n  ${YELLOW}Skipped.${RESET}\n"
        STREAK=0
        press_enter
        return 1
    fi

    if [[ "$choice" == "h" ]]; then
        printf "\n  ${YELLOW}Hint:${RESET} ${WHITE}%s${RESET}\n" "$hint"
        HINTS_USED=$((HINTS_USED + 1))
        hint_used=1
        printf "\n  ${DIM}Press Enter to open shell...${RESET}"
        read -r
    fi

    printf "\n  ${DIM}Working dir: %s${RESET}\n" "$arena"
    printf "  ${DIM}Run your commands below. Type 'exit' when done.${RESET}\n\n"
    (cd "$arena" && "$SHELL")

    local passed=0
    if (set +o pipefail; cd "$arena" && eval "$check_code") &>/dev/null; then
        passed=1
    fi

    if (( passed )); then
        local earned=$points
        (( hint_used )) && earned=$(( points / 2 ))

        SCORE=$(( SCORE + earned ))
        STREAK=$(( STREAK + 1 ))
        CHALLENGES_DONE=$(( CHALLENGES_DONE + 1 ))

        header
        printf "  ${GREEN}${BOLD}✓  CORRECT!${RESET}"
        (( STREAK > 1 )) && printf "  ${YELLOW}${BOLD}${STREAK}× STREAK!${RESET}"
        printf "\n\n"
        printf "  ${WHITE}+%d points${RESET}\n\n" "$earned"
        printf "  ${CYAN}Solution:${RESET} ${WHITE}%s${RESET}\n" "$answer"

        if (( SCORE >= LEVEL * 100 )); then
            LEVEL=$(( LEVEL + 1 ))
            echo
            printf "  ${MAGENTA}${BOLD}★  LEVEL UP! You are now Level %d  ★${RESET}\n" "$LEVEL"
        fi
        press_enter
        return 0
    else
        STREAK=0
        header
        printf "  ${RED}${BOLD}✗  Not quite.${RESET}\n\n"
        printf "  ${CYAN}Directory state after your attempt:${RESET}\n\n"
        show_dir_state "$arena"
        echo
        printf "  ${YELLOW}Answer was:${RESET} ${WHITE}%s${RESET}\n" "$answer"
        press_enter
        return 1
    fi
}

# ── Lessons ───────────────────────────────────────────────────────────────────

lesson_navigation() {
    header
    center "${BOLD}${YELLOW}── LESSON 1: Navigation & Exploration ──${RESET}"
    echo
    printf "  Explore the filesystem:\n\n"
    printf "  ${CYAN}ls${RESET}               list directory contents\n"
    printf "  ${CYAN}ls -la${RESET}           long format, including hidden files\n"
    printf "  ${CYAN}ls -d */  ${RESET}        list directories only\n"
    printf "  ${CYAN}pwd${RESET}              print current directory\n"
    printf "  ${CYAN}cd <dir>${RESET}         change directory\n"
    printf "  ${CYAN}find . -name '*.ext'${RESET}   find files by name/extension\n"
    printf "  ${CYAN}find . -type f${RESET}   find only regular files\n"
    printf "  ${CYAN}find . -type d${RESET}   find only directories\n"
    printf "  ${CYAN}wc -l${RESET}            count lines\n"
    echo
    press_enter

    # Challenge 1: reveal hidden files
    local a1; a1=$(new_arena)
    printf 'top-secret\n' > "$a1/.secret"
    printf 'visible\n'    > "$a1/readme.txt"
    printf 'also visible\n' > "$a1/notes.txt"

    run_linux_challenge \
        "Reveal hidden files" \
        "A hidden file (starting with .) lurks in this directory.\nFind it and write its name (just the filename) to 'found.txt'." \
        "$a1" \
        'grep -qx "\.secret" found.txt || grep -qx ".secret" found.txt' \
        "ls -la shows hidden files; then: echo .secret > found.txt" \
        "ls -la  →  echo .secret > found.txt" \
        15

    # Challenge 2: count files by extension
    local a2; a2=$(new_arena)
    printf 'log1\n' > "$a2/app.log"
    printf 'log2\n' > "$a2/server.log"
    printf 'log3\n' > "$a2/error.log"
    printf 'data\n' > "$a2/readme.txt"
    mkdir -p "$a2/archive"
    printf 'old\n' > "$a2/archive/old.log"

    run_linux_challenge \
        "Count files by extension" \
        "This directory tree contains several .log files (including subdirectories).\nCount all .log files recursively and write the number to 'count.txt'." \
        "$a2" \
        '[[ -f count.txt ]] && [[ $(tr -d " \t\n" < count.txt) -eq 4 ]]' \
        "find . -name '*.log' | wc -l | tr -d ' ' > count.txt" \
        "find . -name '*.log' | wc -l | tr -d ' ' > count.txt" \
        20

    # Challenge 3: navigate to nested content
    local a3; a3=$(new_arena)
    mkdir -p "$a3/a/b/c"
    printf 'treasure\n' > "$a3/a/b/c/treasure.txt"

    run_linux_challenge \
        "Dig out a buried file" \
        "A file 'treasure.txt' is buried inside a/b/c/.\nCopy it to the current (top-level) directory." \
        "$a3" \
        '[[ -f treasure.txt ]] && grep -q "treasure" treasure.txt' \
        "cp a/b/c/treasure.txt .  (or use find to locate it first)" \
        "cp a/b/c/treasure.txt ." \
        15

    # Challenge 4: list only subdirectories
    local a4; a4=$(new_arena)
    mkdir -p "$a4/docs" "$a4/src" "$a4/tests"
    printf 'file\n' > "$a4/readme.txt"
    printf 'file\n' > "$a4/Makefile"

    run_linux_challenge \
        "List only directories" \
        "The working directory has both files and subdirectories.\nWrite the names of all immediate subdirectories to 'dirs.txt' (one per line, no trailing slash)." \
        "$a4" \
        'grep -q "docs" dirs.txt && grep -q "src" dirs.txt && grep -q "tests" dirs.txt && ! grep -q "readme" dirs.txt' \
        "ls -d */ | tr -d '/' > dirs.txt  (or: find . -maxdepth 1 -mindepth 1 -type d)" \
        "ls -d */ | tr -d '/' > dirs.txt" \
        20
}

lesson_file_operations() {
    header
    center "${BOLD}${YELLOW}── LESSON 2: File Operations ──${RESET}"
    echo
    printf "  Creating, copying, moving, and removing files:\n\n"
    printf "  ${CYAN}touch <file>${RESET}           create empty file / update timestamp\n"
    printf "  ${CYAN}cp <src> <dst>${RESET}         copy file\n"
    printf "  ${CYAN}cp -r <src> <dst>${RESET}      copy directory recursively\n"
    printf "  ${CYAN}mv <src> <dst>${RESET}         move or rename\n"
    printf "  ${CYAN}rm <file>${RESET}              remove file\n"
    printf "  ${CYAN}rm -r <dir>${RESET}            remove directory recursively\n"
    printf "  ${CYAN}rm *.ext${RESET}               remove files matching glob\n"
    printf "  ${CYAN}mkdir <dir>${RESET}            create directory\n"
    printf "  ${CYAN}mkdir -p a/b/c${RESET}         create nested directories\n"
    printf "  ${CYAN}cat <file>${RESET}             print file contents\n"
    printf "  ${CYAN}head -n N <file>${RESET}       first N lines\n"
    printf "  ${CYAN}tail -n N <file>${RESET}       last N lines\n"
    echo
    press_enter

    # Challenge 1: copy file to subdirectory
    local a1; a1=$(new_arena)
    mkdir -p "$a1/backup"
    printf 'important data\n' > "$a1/data.txt"

    run_linux_challenge \
        "Copy a file into a directory" \
        "'data.txt' exists at the top level. A 'backup/' directory also exists.\nCopy 'data.txt' into 'backup/' so both copies exist." \
        "$a1" \
        '[[ -f data.txt ]] && [[ -f backup/data.txt ]]' \
        "cp data.txt backup/" \
        "cp data.txt backup/" \
        10

    # Challenge 2: rename a file
    local a2; a2=$(new_arena)
    printf 'script content\n' > "$a2/script.sh.bak"

    run_linux_challenge \
        "Rename a file" \
        "'script.sh.bak' should be renamed to 'script.sh'.\nThe old name should no longer exist." \
        "$a2" \
        '[[ -f script.sh ]] && ! [[ -f script.sh.bak ]]' \
        "mv script.sh.bak script.sh" \
        "mv script.sh.bak script.sh" \
        10

    # Challenge 3: create a nested directory structure
    local a3; a3=$(new_arena)

    run_linux_challenge \
        "Create nested directories" \
        "Create the directory structure: src/components/ui/\n(all three levels must exist with a single command)." \
        "$a3" \
        '[[ -d src/components/ui ]]' \
        "mkdir -p creates all intermediate directories" \
        "mkdir -p src/components/ui" \
        15

    # Challenge 4: remove files matching a pattern
    local a4; a4=$(new_arena)
    printf 'a\n' > "$a4/file1.tmp"
    printf 'b\n' > "$a4/file2.tmp"
    printf 'c\n' > "$a4/file3.tmp"
    printf 'keep\n' > "$a4/important.txt"
    printf 'keep\n' > "$a4/readme.md"

    run_linux_challenge \
        "Delete files by pattern" \
        "Three '.tmp' files exist alongside important files.\nDelete all '.tmp' files without touching the others." \
        "$a4" \
        '! ls *.tmp 2>/dev/null | grep -q "tmp" && [[ -f important.txt ]] && [[ -f readme.md ]]' \
        "rm *.tmp" \
        "rm *.tmp" \
        15

    # Challenge 5: read first and last lines
    local a5; a5=$(new_arena)
    seq 1 20 | awk '{print "line " $1}' > "$a5/numbers.txt"

    run_linux_challenge \
        "Extract first and last lines" \
        "'numbers.txt' has 20 lines (\"line 1\" through \"line 20\").\nWrite the first line to 'first.txt' and the last line to 'last.txt'." \
        "$a5" \
        'grep -qx "line 1" first.txt && grep -qx "line 20" last.txt' \
        "head -n 1 numbers.txt > first.txt  &&  tail -n 1 numbers.txt > last.txt" \
        "head -n 1 numbers.txt > first.txt  &&  tail -n 1 numbers.txt > last.txt" \
        15
}

lesson_text_processing() {
    header
    center "${BOLD}${YELLOW}── LESSON 3: Text Processing ──${RESET}"
    echo
    printf "  Slice, dice, and search text:\n\n"
    printf "  ${CYAN}grep 'pattern' <file>${RESET}      print matching lines\n"
    printf "  ${CYAN}grep -i${RESET}                    case-insensitive match\n"
    printf "  ${CYAN}grep -v 'pattern'${RESET}          invert match (non-matching lines)\n"
    printf "  ${CYAN}grep -c${RESET}                    count matching lines\n"
    printf "  ${CYAN}grep -r 'pattern' .${RESET}        recursive search\n"
    printf "  ${CYAN}sort <file>${RESET}                sort lines alphabetically\n"
    printf "  ${CYAN}sort -n${RESET}                    numeric sort\n"
    printf "  ${CYAN}sort -r${RESET}                    reverse sort\n"
    printf "  ${CYAN}uniq${RESET}                       remove adjacent duplicates\n"
    printf "  ${CYAN}sort | uniq -c${RESET}             count occurrences\n"
    printf "  ${CYAN}wc -l / -w / -c${RESET}            count lines / words / chars\n"
    printf "  ${CYAN}cut -d',' -f2${RESET}              extract field 2 (CSV)\n"
    echo
    press_enter

    # Challenge 1: grep for matching lines
    local a1; a1=$(new_arena)
    cat > "$a1/server.log" << 'EOF'
2024-01-01 INFO  server started
2024-01-01 ERROR connection refused
2024-01-01 INFO  request received
2024-01-02 ERROR timeout exceeded
2024-01-02 INFO  response sent
2024-01-02 ERROR disk full
EOF

    run_linux_challenge \
        "Filter log by level" \
        "'server.log' contains mixed INFO and ERROR lines.\nExtract only the ERROR lines into 'errors.txt'." \
        "$a1" \
        '[[ -f errors.txt ]] && grep -q "ERROR" errors.txt && ! grep -q "INFO" errors.txt' \
        "grep 'ERROR' server.log > errors.txt" \
        "grep 'ERROR' server.log > errors.txt" \
        15

    # Challenge 2: sort and deduplicate
    local a2; a2=$(new_arena)
    cat > "$a2/words.txt" << 'EOF'
banana
apple
cherry
apple
banana
date
cherry
cherry
EOF

    run_linux_challenge \
        "Sort and deduplicate" \
        "'words.txt' has duplicate entries out of order.\nWrite a sorted, deduplicated list to 'unique.txt'." \
        "$a2" \
        '[[ -f unique.txt ]] && [[ $(wc -l < unique.txt | tr -d " ") -eq 4 ]] && grep -qx "apple" unique.txt' \
        "sort words.txt | uniq > unique.txt" \
        "sort words.txt | uniq > unique.txt" \
        15

    # Challenge 3: count occurrences
    local a3; a3=$(new_arena)
    cat > "$a3/access.log" << 'EOF'
GET /home
POST /api
GET /home
GET /about
POST /api
GET /home
GET /contact
POST /login
GET /home
EOF

    run_linux_challenge \
        "Count most-visited paths" \
        "'access.log' has one URL path per line.\nWrite a frequency-sorted count to 'freq.txt'.\nEach line: \"  N path\" with the most-visited first.\n\n${DIM}Tip: cut -d' ' -f2 | sort | uniq -c | sort -rn${RESET}" \
        "$a3" \
        '[[ -f freq.txt ]] && head -1 freq.txt | grep -q "4"' \
        "cut -d' ' -f2 access.log | sort | uniq -c | sort -rn > freq.txt" \
        "cut -d' ' -f2 access.log | sort | uniq -c | sort -rn > freq.txt" \
        25

    # Challenge 4: extract CSV column
    local a4; a4=$(new_arena)
    cat > "$a4/data.csv" << 'EOF'
alice,30,engineer
bob,25,designer
carol,35,manager
dave,28,engineer
EOF

    run_linux_challenge \
        "Extract a CSV column" \
        "'data.csv' has three columns: name, age, role.\nExtract just the names (column 1) into 'names.txt'." \
        "$a4" \
        '[[ -f names.txt ]] && grep -qx "alice" names.txt && grep -qx "bob" names.txt && ! grep -q "engineer" names.txt' \
        "cut -d',' -f1 data.csv > names.txt" \
        "cut -d',' -f1 data.csv > names.txt" \
        20

    # Challenge 5: grep -v to exclude
    local a5; a5=$(new_arena)
    cat > "$a5/config.txt" << 'EOF'
# This is a comment
host=localhost
# Another comment
port=8080
# Debug mode
debug=false
EOF

    run_linux_challenge \
        "Strip comments from config" \
        "'config.txt' has lines starting with '#' (comments) and real config.\nWrite only the non-comment lines to 'config.clean'." \
        "$a5" \
        '[[ -f config.clean ]] && ! grep -q "^#" config.clean && grep -q "host=" config.clean' \
        "grep -v '^#' config.txt > config.clean" \
        "grep -v '^#' config.txt > config.clean" \
        20
}

lesson_redirection() {
    header
    center "${BOLD}${YELLOW}── LESSON 4: Streams & Redirection ──${RESET}"
    echo
    printf "  Control where input and output flow:\n\n"
    printf "  ${CYAN}command > file${RESET}       redirect stdout, overwrite\n"
    printf "  ${CYAN}command >> file${RESET}      redirect stdout, append\n"
    printf "  ${CYAN}command < file${RESET}       use file as stdin\n"
    printf "  ${CYAN}command 2> file${RESET}      redirect stderr\n"
    printf "  ${CYAN}command 2>&1${RESET}         merge stderr into stdout\n"
    printf "  ${CYAN}cmd1 | cmd2${RESET}          pipe stdout of cmd1 to stdin of cmd2\n"
    printf "  ${CYAN}tee <file>${RESET}           write to file AND stdout simultaneously\n"
    printf "  ${CYAN}xargs${RESET}                build and execute commands from stdin\n"
    echo
    printf "  ${DIM}File descriptors: 0=stdin, 1=stdout, 2=stderr${RESET}\n"
    echo
    press_enter

    # Challenge 1: redirect output to file
    local a1; a1=$(new_arena)
    printf 'alpha\nbeta\ngamma\n' > "$a1/input.txt"

    run_linux_challenge \
        "Redirect to a file" \
        "Sort 'input.txt' alphabetically and save the result to 'sorted.txt'.\nDo not modify 'input.txt'." \
        "$a1" \
        '[[ -f sorted.txt ]] && [[ $(head -1 sorted.txt) == "alpha" ]] && [[ -f input.txt ]]' \
        "sort input.txt > sorted.txt" \
        "sort input.txt > sorted.txt" \
        10

    # Challenge 2: append to a file
    local a2; a2=$(new_arena)
    printf 'first line\n' > "$a2/log.txt"
    printf 'second line\n' > "$a2/more.txt"

    run_linux_challenge \
        "Append to a file" \
        "'log.txt' has one line. Append the contents of 'more.txt' to it.\n'log.txt' should end up with both lines." \
        "$a2" \
        '[[ $(wc -l < log.txt | tr -d " ") -eq 2 ]] && grep -q "first line" log.txt && grep -q "second line" log.txt' \
        "cat more.txt >> log.txt" \
        "cat more.txt >> log.txt" \
        10

    # Challenge 3: pipeline combining commands
    local a3; a3=$(new_arena)
    printf 'error: disk full\ninfo: started\nerror: timeout\nwarn: slow\nerror: crash\n' > "$a3/events.log"

    run_linux_challenge \
        "Count with a pipeline" \
        "'events.log' has mixed event types.\nCount the number of 'error:' lines and write the number to 'error_count.txt'." \
        "$a3" \
        '[[ -f error_count.txt ]] && [[ $(tr -d " \t\n" < error_count.txt) -eq 3 ]]' \
        "grep 'error:' events.log | wc -l | tr -d ' ' > error_count.txt" \
        "grep 'error:' events.log | wc -l | tr -d ' ' > error_count.txt" \
        20

    # Challenge 4: suppress stderr
    local a4; a4=$(new_arena)
    printf 'real output\n' > "$a4/good.txt"

    run_linux_challenge \
        "Silence stderr" \
        "Run: cat good.txt nonexistent.txt\nCapture only stdout to 'out.txt' (stderr errors should be discarded).\n'out.txt' should contain just \"real output\"." \
        "$a4" \
        '[[ -f out.txt ]] && grep -qx "real output" out.txt && ! grep -q "No such file" out.txt' \
        "cat good.txt nonexistent.txt 2>/dev/null > out.txt" \
        "cat good.txt nonexistent.txt 2>/dev/null > out.txt" \
        20

    # Challenge 5: tee
    local a5; a5=$(new_arena)
    printf 'apple\nbanana\ncherry\n' > "$a5/fruits.txt"

    run_linux_challenge \
        "Use tee to split output" \
        "Sort 'fruits.txt' and save the sorted result to 'sorted.txt'.\nAlso count the sorted lines and save the count to 'count.txt'.\n\n${DIM}Tip: sort fruits.txt | tee sorted.txt | wc -l > count.txt${RESET}" \
        "$a5" \
        '[[ -f sorted.txt ]] && [[ -f count.txt ]] && [[ $(tr -d " \t\n" < count.txt) -eq 3 ]] && [[ $(head -1 sorted.txt) == "apple" ]]' \
        "sort fruits.txt | tee sorted.txt | wc -l | tr -d ' ' > count.txt" \
        "sort fruits.txt | tee sorted.txt | wc -l | tr -d ' ' > count.txt" \
        25
}

lesson_permissions() {
    header
    center "${BOLD}${YELLOW}── LESSON 5: Permissions ──${RESET}"
    echo
    printf "  Linux permission model:\n\n"
    printf "  ${CYAN}ls -l${RESET}             show permissions: -rwxrwxrwx\n"
    printf "                     [type][owner][group][others]\n\n"
    printf "  ${CYAN}chmod +x file${RESET}     add execute bit (all)\n"
    printf "  ${CYAN}chmod -w file${RESET}     remove write bit (all)\n"
    printf "  ${CYAN}chmod 644 file${RESET}    numeric: rw-r--r--\n"
    printf "  ${CYAN}chmod 755 file${RESET}    numeric: rwxr-xr-x\n"
    printf "  ${CYAN}chmod 700 file${RESET}    numeric: rwx------\n\n"
    printf "  ${BOLD}Numeric notation:${RESET}  4=read  2=write  1=execute\n"
    printf "  Add them up:  7=rwx  6=rw-  5=r-x  4=r--\n\n"
    printf "  ${CYAN}find . -perm /111${RESET} find executable files\n"
    printf "  ${CYAN}find . -perm 644${RESET}  find files with exact permissions\n"
    echo
    press_enter

    # Challenge 1: make a script executable
    local a1; a1=$(new_arena)
    printf '#!/bin/bash\necho hello\n' > "$a1/greet.sh"
    chmod 644 "$a1/greet.sh"

    run_linux_challenge \
        "Make a script executable" \
        "'greet.sh' exists but is not executable.\nAdd the execute permission so it can be run." \
        "$a1" \
        '[[ -x greet.sh ]]' \
        "chmod +x greet.sh  (or: chmod 755 greet.sh)" \
        "chmod +x greet.sh" \
        10

    # Challenge 2: set numeric permissions
    local a2; a2=$(new_arena)
