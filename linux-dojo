# ── Entry point ───────────────────────────────────────────────────────────────

main() {
    clear_screen
    echo
    center "${BOLD}${BLUE}>_  LINUX DOJO  _<${RESET}"
    echo
    center "${DIM}Practice Linux commands. Master the shell.${RESET}"
    echo
    printf "  How it works:\n\n"
    printf "  1. Choose a lesson from the menu.\n"
    printf "  2. Read the challenge — a temporary working directory is set up for you.\n"
    printf "  3. Press Enter — a shell opens inside that directory.\n"
    printf "  4. Run Linux commands to complete the challenge.\n"
    printf "  5. Type ${CYAN}exit${RESET} when done — your work is checked automatically.\n\n"
    printf "  ${DIM}Press h before opening the shell to get a hint (half points).${RESET}\n"
    printf "  ${DIM}Press s to skip a challenge.${RESET}\n"
    printf "  ${DIM}All arenas are isolated temp directories — nothing on your system is affected.${RESET}\n"
    echo
    press_enter

    while true; do
        show_menu
        local choice
        read -r choice

        case "$choice" in
            1) lesson_navigation ;;
            2) lesson_file_operations ;;
            3) lesson_text_processing ;;
            4) lesson_redirection ;;
            5) lesson_permissions ;;
            6) lesson_archives ;;
            7) lesson_find_xargs ;;
            8) lesson_sed_awk ;;
            9) lesson_bash_scripting ;;
            10) lesson_process_system ;;
            11) lesson_file_comparison ;;
            12) lesson_integrity ;;
            r|R) random_challenge ;;
            '?') quick_reference ;;
            q|Q)
                clear_screen
                echo
                center "${BOLD}${YELLOW}Thanks for training at Linux Dojo!${RESET}"
                echo
                center "Final score:           ${WHITE}${BOLD}${SCORE}${RESET}"
                center "Challenges completed:  ${WHITE}${BOLD}${CHALLENGES_DONE}${RESET}"
                center "Hints used:            ${WHITE}${BOLD}${HINTS_USED}${RESET}"
                center "Level reached:         ${WHITE}${BOLD}${LEVEL}${RESET}"
                echo
                center "${DIM}The best way to learn Linux is to use Linux. Keep practicing.${RESET}"
                echo
                exit 0
                ;;
            *) ;;
        esac
    done
}

main "$@"
