lesson_file_comparison() {
    header
    center "${BOLD}${YELLOW}── LESSON 11: File Comparison ──${RESET}"
    echo
    printf "  Compare and reconcile files:\n\n"
    printf "  ${CYAN}diff file1 file2${RESET}            show differences\n"
    printf "  ${CYAN}diff -u file1 file2${RESET}         unified diff (patch-friendly)\n"
    printf "  ${CYAN}diff -r dir1 dir2${RESET}           compare directory trees\n"
    printf "  ${CYAN}patch file < patch.diff${RESET}     apply a diff to a file\n"
    printf "  ${CYAN}patch -p1 < patch.diff${RESET}      apply unified diff (strip 1 path component)\n"
    printf "  ${CYAN}comm file1 file2${RESET}            lines unique/common between sorted files\n"
    printf "  ${CYAN}comm -12 file1 file2${RESET}        only common lines\n"
    printf "  ${CYAN}comm -23 file1 file2${RESET}        only in file1 (not file2)\n"
    printf "  ${CYAN}comm -13 file1 file2${RESET}        only in file2 (not file1)\n"
    echo
    printf "  ${DIM}Note: comm requires both files to be sorted.${RESET}\n"
    echo
    press_enter

    # Challenge 1: diff two files
    local a1; a1=$(new_arena)
    printf 'line one\nline two\nline three\n' > "$a1/v1.txt"
    printf 'line one\nline TWO\nline three\n' > "$a1/v2.txt"

    run_linux_challenge \
        "Find the difference" \
        "'v1.txt' and 'v2.txt' differ on one line.\nRun diff on them and save the output to 'changes.diff'." \
        "$a1" \
        '[[ -f changes.diff ]] && grep -q "TWO\|two" changes.diff' \
        "diff v1.txt v2.txt > changes.diff" \
        "diff v1.txt v2.txt > changes.diff" \
