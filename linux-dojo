    printf 'one\n'   > "$a9/level1/one.txt"
    printf 'deep\n'  > "$a9/level1/level2/two.txt"
    printf 'deeper\n' > "$a9/level1/level2/level3/three.txt"

    run_linux_challenge \
        "Search only the top two levels" \
        "Files are nested across multiple directory levels.\nFind all .txt files within a maximum depth of 2 (top dir + one level down)\nand write their basenames to 'shallow.txt'." \
        "$a9" \
        '[[ -f shallow.txt ]] && grep -q "top.txt" shallow.txt && grep -q "one.txt" shallow.txt && ! grep -q "two.txt" shallow.txt && ! grep -q "three.txt" shallow.txt' \
        "find . -maxdepth 2 -name '*.txt' -exec basename {} \\; > shallow.txt" \
