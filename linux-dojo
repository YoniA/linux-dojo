    run_linux_challenge \
        "Make all scripts executable" \
        "The 'scripts/' directory has .sh files that need execute permission.\nUse find + exec (or xargs) to chmod +x all .sh files at once." \
        "$a2" \
        '[[ -x scripts/deploy.sh ]] && [[ -x scripts/build.sh ]] && [[ -x scripts/test.sh ]]' \
        "find scripts/ -name '*.sh' -exec chmod +x {} +" \
