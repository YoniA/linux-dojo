        '[[ -f executables.txt ]] && grep -q "runner.sh" executables.txt && grep -q "start.sh" executables.txt && ! grep -q "config.cfg" executables.txt' \
        "find . -type f -perm -u+x -exec basename {} \\; > executables.txt" \
        "find . -type f -perm -u+x -exec basename {} \\; > executables.txt" \
        20

